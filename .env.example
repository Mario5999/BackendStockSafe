# Opcion A: URL completa de conexion (prioridad alta)
# En Vercel puedes configurar DATABASE_URL con la External Database URL de Render.
# DATABASE_URL=postgresql://usuario:password@host:5432/stocksafe

# Opcion B: Variables separadas
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=stocksafe
# Render normalmente requiere SSL en conexiones externas.
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# Seguridad de autenticacion
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=12

# Frontend movil / web
# Cargar esta URL en Vercel y en Expo segun corresponda.
APP_URL=

# Seleccion de contexto de pruebas para endpoints sin autenticacion
# Si no se define, se usa el primer restaurante encontrado.
DEFAULT_RESTAURANT_ID=
DEFAULT_RESTAURANT_EMAIL=

# Para registrar movimientos/verificaciones automaticamente.
# Si no se define, el backend intenta usar un usuario 'empleado' del restaurante.
DEFAULT_RESTAURANT_USER_ID=
DEFAULT_RESTAURANT_USER_ROLE=empleado
