# Opcion A: URL completa de conexion (prioridad alta)
# DATABASE_URL=postgresql://postgres:postgres@10.20.30.40:5432/stocksafe

# Opcion B: Variables separadas
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=stocksafe
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# Seleccion de contexto de pruebas para endpoints sin autenticacion
# Si no se define, se usa el primer restaurante encontrado.
DEFAULT_RESTAURANT_ID=
DEFAULT_RESTAURANT_EMAIL=

# Para registrar movimientos/verificaciones automaticamente.
# Si no se define, el backend intenta usar un usuario 'empleado' del restaurante.
DEFAULT_RESTAURANT_USER_ID=
DEFAULT_RESTAURANT_USER_ROLE=empleado
